# Anthropic API — 같은 카테고리 유사어 10개 생성용. 미설정 시 라우트가 503으로 응답.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Supabase — 인증 + DB
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role 키: 서버 전용. 관리자 페이지의 사용자 목록 조회 등 RLS 우회용.
# 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것.
SUPABASE_SERVICE_ROLE_KEY=

# 관리자 이메일 — 이 이메일로 가입하면 자동으로 admin 역할이 부여됨.
ADMIN_EMAIL=oiasungjin@gmail.com

# ── 기능 공개 게이트 (나의 인지근육) ───────────────────────────────
# 인지근육 리포트는 개발 중. 일반 사용자에겐 '준비중' 화면을 보여주고,
# 아래 조건 중 하나면 실제 리포트가 열린다.
#   1) 전체공개 스위치: 완성되면 true 로 바꾸면 전원 공개되고 '준비중' 배지도 사라짐.
NEXT_PUBLIC_COGNITION_ENABLED=false
#   2) 로컬 개발(npm run dev)에서는 위 값과 무관하게 항상 열림.
#   3) 관리자 미리보기: 아래 이메일로 로그인하면 배포본에서도 열림.
#      (ADMIN_EMAIL 과 같은 값. 클라이언트 노출용이라 NEXT_PUBLIC_ 접두사 필요)
NEXT_PUBLIC_ADMIN_EMAIL=oiasungjin@gmail.com
