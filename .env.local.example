# Anthropic API — 같은 카테고리 유사어 10개 생성용. 미설정 시 라우트가 503으로 응답.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Supabase — 인증 + DB
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role 키: 서버 전용. 관리자 페이지의 사용자 목록 조회 등 RLS 우회용.
# 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것.
SUPABASE_SERVICE_ROLE_KEY=

# 관리자 이메일 — 이 이메일로 가입하면 자동으로 admin 역할이 부여됨.
ADMIN_EMAIL=planb4u@planb4u.kr
